# ============================================================================
# Bite&Go Auth Service - Plantilla de variables de entorno
# ============================================================================
# Este archivo SÍ se commitea (es la plantilla). NO pongas valores reales aquí.
#
# Pasos para compañeros al clonar:
#   1) cp auth-service-bite-go/.env.example  auth-service-bite-go/.env
#   2) Rellena los valores reales (SMTP/Cloudinary propios o los del equipo)
#   3) Nunca commitees .env — ya está en .gitignore
#
# Formato: ASP.NET Core traduce `Seccion__Llave` a `Seccion:Llave` en
# IConfiguration. Por eso doble guion bajo en lugar de dos puntos.
# ============================================================================

# --- SMTP (Gmail con App Password de 16 caracteres SIN espacios) ------------
# Cómo generar una App Password: https://myaccount.google.com/apppasswords
SmtpSettings__Host=smtp.gmail.com
SmtpSettings__Port=465
SmtpSettings__Username=tu-correo@gmail.com
SmtpSettings__Password=xxxxxxxxxxxxxxxx
SmtpSettings__FromEmail=tu-correo@gmail.com
SmtpSettings__FromName=Bite&Go
SmtpSettings__Enabled=true
SmtpSettings__UseImplicitSsl=true

# --- Cloudinary (avatar / foto de perfil) -----------------------------------
# Valores en https://console.cloudinary.com → Dashboard
CloudinarySettings__CloudName=tu_cloud_name
CloudinarySettings__ApiKey=tu_api_key
CloudinarySettings__ApiSecret=tu_api_secret
CloudinarySettings__BaseUrl=https://res.cloudinary.com/tu_cloud_name/image/upload/v1/bitego_auth/
CloudinarySettings__DefaultAvatarPath=default-avatar_ewzxwx.png
CloudinarySettings__Folder=bitego_auth/profiles

# ============================================================================
# Solo necesario si ejecutas el servicio FUERA de Docker (dotnet run):
# ============================================================================
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=bitego_auth_db;Username=bitego;Password=bitego
# JwtSettings__SecretKey=genera_una_clave_aleatoria_muy_larga_aqui
# JwtSettings__Issuer=BiteGoAuthService
# JwtSettings__Audience=BiteGoServices
# AppSettings__FrontendUrl=http://localhost:5173
